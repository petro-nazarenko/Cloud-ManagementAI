# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_MAX=100
ENABLE_DEMO_SEEDING=true

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cloudmgmt
DB_USER=cloudmgmt_admin
DB_PASSWORD=replace-with-a-strong-database-password
DB_SSL=false

# ─── Queue / Jobs ─────────────────────────────────────────────────────────────
# Use redis in development/production. Tests fall back to inline mode.
REDIS_URL=redis://localhost:6379
QUEUE_MODE=redis

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
ENCRYPTION_KEY=replace-with-64-hex-characters-for-aes-256-gcm

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# AWS_SESSION_TOKEN=  # optional, for temporary credentials
AWS_DEFAULT_REGION=us-east-1

# ─── Azure ────────────────────────────────────────────────────────────────────
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id

# ─── GCP ──────────────────────────────────────────────────────────────────────
# Path to your GCP service-account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-service-account.json
